#include "unitary.hpp"

extern "C"
{
    void @name@(uint32_t num, @type@ *in, @type@ *out)
    {
#pragma HLS interface m_axi port=in bundle=gmem0
#pragma HLS interface m_axi port=out bundle=gmem1
@pragma@
        stream_operation<@type@>(num, in, out, hls::@function@);
    }
}
