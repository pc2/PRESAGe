#include "binary.hpp"

template <int Bits, bool Float, int Id>
void Binary<Bits, Float, Id>::run(sycl::queue &q, uint64_t num,
                          sycl::buffer<PipeType, 1> &a,
                          sycl::buffer<PipeType, 1> &b,
                          sycl::buffer<PipeType, 1> &c)
{
    q.submit([&](sycl::handler &h) {
        sycl::accessor a_accessor(a, h, sycl::read_only);
        sycl::accessor b_accessor(b, h, sycl::read_only);
        h.single_task<ReadKernel<Bits, Float>>([=]() [[intel::kernel_args_restrict]] {
            for (size_t i = 0; i < num; i++) {
                ReadAPipe::write(a_accessor[i]);
                ReadBPipe::write(b_accessor[i]);
            }
        });
    });

    q.submit([&](sycl::handler &h) {
        h.single_task<OperationKernel<Bits, Float, Id>>([=]() [[intel::kernel_args_restrict]] {
            for (size_t i = 0; i < num; i++) {
                PipeType a_bits = ReadAPipe::read();
                PipeType b_bits = ReadBPipe::read();
                PipeType c_bits;
                if constexpr (Float) {
                    if constexpr (Bits == 16) {
                        ihc::ap_float<5, 10> local_a = reinterpret_cast<ihc::ap_float<5, 10>&>(a_bits);
                        ihc::ap_float<5, 10> local_b = reinterpret_cast<ihc::ap_float<5, 10>&>(b_bits);
                        ihc::ap_float<5, 10> local_c = @operation@(local_a, local_b);
                        c_bits = reinterpret_cast<PipeType&>(local_c);
                    } else if constexpr (Bits == 32) {
                        float local_a = reinterpret_cast<float&>(a_bits);
                        float local_b = reinterpret_cast<float&>(b_bits);
                        float local_c = @operation@(local_a, local_b);
                        c_bits = reinterpret_cast<PipeType&>(local_c);
                    } else {
                        double local_a = reinterpret_cast<double&>(a_bits);
                        double local_b = reinterpret_cast<double&>(b_bits);
                        double local_c = @operation@(local_a, local_b);
                        c_bits = reinterpret_cast<PipeType&>(local_c);
                    }
                } else {
                    c_bits = @operation@<Bits>(a_bits, b_bits);
                }
                WritePipe::write(c_bits);
                
            }
        });
    });

    q.submit([&](sycl::handler &h) {
        sycl::accessor c_accessor(c, h, sycl::write_only, sycl::no_init);
        h.single_task<WriteKernel<Bits, Float>>([=]() [[intel::kernel_args_restrict]] {
            for (size_t i = 0; i < num; i++) {
               c_accessor[i] = WritePipe::read();
            }
        });
    });

    q.wait();
}

template <int Bits, bool Float, int Id>
std::string Binary<Bits, Float, Id>::get_name()
{
    return "@operation@";
}

#ifndef EMULATION
template class Binary<16, true, -16>;
#endif
template class Binary<32, true, -32>;
template class Binary<64, true, -64>;

